{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["es2020"]
    // "types": ["node", "express"]  ← REMOVE THIS LINE
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
